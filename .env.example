# Copy this file to `.env` and fill in the values.
# docker-compose loads it into the `app` container (see docker-compose.yml).

# REQUIRED. Secret used to sign/encrypt cookies and other secrets.
# Generate one with:  mix phx.gen.secret      (or:  openssl rand -base64 48)
SECRET_KEY_BASE=

# Public hostname used for URL generation. For local testing use: localhost
PHX_HOST=localhost

# --- Optional overrides (sensible defaults apply if unset) ---
# SQLite connection pool size (default: 10)
# POOL_SIZE=10
# libcluster DNS query for multi-node clustering (default: disabled)
# DNS_CLUSTER_QUERY=
#
# Note: PORT, DATABASE_PATH and PHX_SERVER are already set for you in docker-compose.yml.
