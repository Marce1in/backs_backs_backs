# Copy this file to `.env` and fill in the values.
# docker-compose loads it into the `app` container (see docker-compose.yml).

# REQUIRED. Secret used to sign/encrypt cookies and other secrets.
# Generate one with:  mix phx.gen.secret      (or:  openssl rand -base64 48)
SECRET_KEY_BASE=

# Public hostname used for URL generation. For local testing use: localhost
PHX_HOST=localhost

# GitHub OAuth App credentials.
# Callback URL must match GITHUB_CALLBACK_URL, for example:
#   http://localhost:4000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# Comma-separated extension redirect URIs accepted by the backend.
# In Chrome this comes from browser.identity.getRedirectURL("github").
EXTENSION_REDIRECT_URIS=

# Server-side OpenRouter credentials used for all users.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/owl-alpha
TAB_ORGANIZER_INTERVAL_MS=300000

# --- Optional overrides (sensible defaults apply if unset) ---
# SQLite connection pool size (default: 10)
# POOL_SIZE=10
# libcluster DNS query for multi-node clustering (default: disabled)
# DNS_CLUSTER_QUERY=
#
# Note: PORT, DATABASE_PATH and PHX_SERVER are already set for you in docker-compose.yml.
